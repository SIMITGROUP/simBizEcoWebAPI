  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'x-uid', value: pm.variables.get('uid') });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth and System",
      "item": [
        {
          "name": "Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let body = {};",
                  "try { body = pm.response.json(); } catch (e) {}",
                  "if (body && body.status === 'OK' && body.data && body.data.token) {",
                  "  pm.environment.set('token', body.data.token);",
                  "}",
                  "pm.test('Token API returns status OK', function () {",
                  "  pm.expect(body.status).to.eql('OK');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uid\": \"{{uid}}\",\n  \"secret\": \"{{secret}}\",\n  \"organization_code\": \"{{organization_code}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v3/token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v3",
                "token"
              ]
            }
          }
        },
        {
          "name": "Health Check",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
